# Database Connection (PostgreSQL URL format - same as root .env)
# The API automatically converts this to .NET connection string format
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ardanova

# API Key Authentication (same as root .env)
API_KEY=dev-api-key-12345

# ASP.NET Core (optional)
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Note: This API reads DATABASE_URL and API_KEY directly from environment variables,
# so it shares the same .env file as the Next.js client.
