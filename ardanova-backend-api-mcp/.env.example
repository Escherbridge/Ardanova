# ===========================================
# ArdaNova Backend API - Environment Config
# ===========================================
# NOTE: In production/Docker, use the ROOT .env file instead.
# This file is for standalone local development only.

# ===========================================
# Database Connection
# ===========================================
# Required. PostgreSQL URL format is automatically converted to a .NET
# connection string. Keep it in an ignored local .env or deployment secret store.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ardanova

# ===========================================
# API Security
# ===========================================
# Shared service key; every environment requires at least 32 UTF-8 bytes.
API_KEY=
# Distinct privileged key shared only with the frontend BFF. Production
# readiness requires at least 32 bytes.
ADMIN_API_KEY=
# Exact same sealed 32+ byte value as the frontend BFF uses to sign actors.
ACTOR_ASSERTION_HMAC_KEY=
# ===========================================
# AZOA integration (safe default: disabled/simulated)
# ===========================================
Azoa__BaseUrl=
# Onboarding/custody only: tenant:provision,wallet:manage,kyc:read,kyc:submit.
Azoa__CustodyApiKey=
# Value only: nft:mint for allocation/fungible mint; add no onboarding scopes.
Azoa__ValueApiKey=
# Quest only. Authoring requires dapp:develop and an API-key owner that holds
# Azoa's persisted dApp Developer role; do not reuse a value or custody key.
Azoa__QuestApiKey=
# Legacy non-Production migration fallback. Production ignores this setting.
Azoa__TenantApiKey=
Azoa__Mode=Simulated
Azoa__ChainType=Algorand
Azoa__TimeoutSeconds=30
Azoa__EnableFundingCheckout=false
Azoa__SelectedSettlementNodeId=
Azoa__EnableSettlementOutboxWorker=false
Azoa__SettlementOutboxBatchSize=10
Azoa__SettlementOutboxIntervalSeconds=15
Azoa__EnableCustodialAccounts=false
# Required when custody is enabled: canonical AZOA tenant avatar GUID.
# Production rejects any key reused across custody, value, or quest transports.
Azoa__TenantId=
Algorand__Provider=Simulated
Algorand__RequireCredentialOperations=false
Algorand__AllowLegacyCustodialSignerInProduction=false

# ===========================================
# ASP.NET Core
# ===========================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ===========================================
# File Storage Configuration
# ===========================================
# Provider: S3, Azure, Local (default: Local)
STORAGE_PROVIDER=Local

# S3 Configuration (AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces)
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=ardanova-files
S3_REGION=us-east-1
# S3_SERVICE_URL=http://localhost:9000
# S3_USE_PATH_STYLE=true

# Local Storage (for development)
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8080/files

# ===========================================
# IMPORTANT NOTE
# ===========================================
# This API shares environment variables with the root .env file.
# For Docker deployments, all services use the root .env file.
# Ensure your configuration matches the root .env.example.
