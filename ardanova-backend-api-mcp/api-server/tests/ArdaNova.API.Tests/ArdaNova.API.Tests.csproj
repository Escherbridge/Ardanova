<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="coverlet.collector" Version="6.0.2" />
    <PackageReference Include="FluentAssertions" Version="6.12.2" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="Moq" Version="4.20.72" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\ArdaNova.Application\ArdaNova.Application.csproj" />
  </ItemGroup>

  <!-- Link EventBus and WebSocket source files, excluding Extensions which have extra ASP.NET dependencies -->
  <ItemGroup>
    <Compile Include="..\..\src\ArdaNova.API\Controllers\StripeWebhookController.cs" Link="Controllers\StripeWebhookController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\FundingIntentsController.cs" Link="Controllers\FundingIntentsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\WalletsController.cs" Link="Controllers\WalletsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\PayoutsController.cs" Link="Controllers\PayoutsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\TokenBalanceController.cs" Link="Controllers\TokenBalanceController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\TaskEscrowsController.cs" Link="Controllers\TaskEscrowsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\OpportunityBidsController.cs" Link="Controllers\OpportunityBidsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\TasksController.cs" Link="Controllers\TasksController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\EpicsController.cs" Link="Controllers\EpicsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\SprintsController.cs" Link="Controllers\SprintsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\FeaturesController.cs" Link="Controllers\FeaturesController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\ProductBacklogItemsController.cs" Link="Controllers\ProductBacklogItemsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\ProjectsController.cs" Link="Controllers\ProjectsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\ProjectTokensController.cs" Link="Controllers\ProjectTokensController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\CredentialUtilityController.cs" Link="Controllers\CredentialUtilityController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\MembershipCredentialsController.cs" Link="Controllers\MembershipCredentialsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\GovernanceController.cs" Link="Controllers\GovernanceController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\ReferralsController.cs" Link="Controllers\ReferralsController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\AzoaAvatarController.cs" Link="Controllers\AzoaAvatarController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Controllers\DelegatedVotesController.cs" Link="Controllers\DelegatedVotesController.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Middleware\ApiKeyMiddleware.cs" Link="Middleware\ApiKeyMiddleware.cs" />
    <Compile Include="..\..\src\ArdaNova.API\Middleware\ActorAssertionMiddleware.cs" Link="Middleware\ActorAssertionMiddleware.cs" />
    <Compile Include="..\..\src\ArdaNova.API\EventBus\Abstractions\*.cs" Link="EventBus\Abstractions\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\ArdaNova.API\EventBus\Events\*.cs" Link="EventBus\Events\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\ArdaNova.API\EventBus\Implementation\*.cs" Link="EventBus\Implementation\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\ArdaNova.API\WebSocket\Clients\*.cs" Link="WebSocket\Clients\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\ArdaNova.API\WebSocket\Handlers\*.cs" Link="WebSocket\Handlers\%(Filename)%(Extension)" />
    <Compile Include="..\..\src\ArdaNova.API\WebSocket\Hubs\*.cs" Link="WebSocket\Hubs\%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Add ASP.NET Core framework for SignalR support -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
    <Using Include="FluentAssertions" />
    <Using Include="Moq" />
    <Using Include="Microsoft.Extensions.Logging" />
    <Using Include="Microsoft.Extensions.Configuration" />
    <Using Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>

</Project>
