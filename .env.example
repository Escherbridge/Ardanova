# ===========================================
# ArdaNova Platform - Root Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# All services reference this root .env file

# ===========================================
# Authentication
# ===========================================
AUTH_SECRET=your-auth-secret-min-32-chars-here
AUTH_URL=http://localhost:3000

# Google OAuth (Primary provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Database
# ===========================================
# Required by the API and web application. Keep this only in an ignored .env
# locally; configure it through the deployment secret manager in production.
DATABASE_URL=postgresql://postgres:password@localhost:5432/ardanova?sslmode=disable

# ===========================================
# Backend API
# ===========================================
API_URL=http://localhost:5147
# Required by the .NET API and must match the web application's server-side key.
# Never add a fallback key to appsettings.json.
API_KEY=
# Distinct privileged server-to-server key shared only by the frontend BFF and
# API. Use a random 32+ byte value and never expose it as NEXT_PUBLIC_*.
ADMIN_API_KEY=
# Shared server-side signing secret for binding frontend BFF requests to the
# authenticated actor. Use the exact same sealed 32+ byte value in both services.
ACTOR_ASSERTION_HMAC_KEY=

# ===========================================
# AZOA integration (safe default: disabled/simulated)
# ===========================================
# Live/provider-backed operation additionally requires an HTTPS base URL and
# separate server-only custody, value, and quest keys. Funding checkout stays disabled
# until a selected settlement node and reconciliation path are verified.
Azoa__BaseUrl=
# Onboarding/custody only: tenant:provision,wallet:manage,kyc:read,kyc:submit.
Azoa__CustodyApiKey=
# Value only: nft:mint for allocation/fungible mint; add no onboarding scopes.
Azoa__ValueApiKey=
# Quest only. Authoring requires dapp:develop and an API-key owner that holds
# Azoa's persisted dApp Developer role; do not reuse a value or custody key.
Azoa__QuestApiKey=
# Legacy non-Production migration fallback. Production ignores this setting.
Azoa__TenantApiKey=
Azoa__Mode=Simulated
Azoa__ChainType=Algorand
Azoa__TimeoutSeconds=30
Azoa__EnableFundingCheckout=false
Azoa__SelectedSettlementNodeId=
Azoa__EnableSettlementOutboxWorker=false
Azoa__SettlementOutboxBatchSize=10
Azoa__SettlementOutboxIntervalSeconds=15
Azoa__EnableCustodialAccounts=false
# Production rejects any key reused across custody, value, or quest transports.
Azoa__TenantId=
Algorand__Provider=Simulated
Algorand__RequireCredentialOperations=false
Algorand__AllowLegacyCustodialSignerInProduction=false
# Optional browser-safe, read-only SDK origin. Never put a tenant key in a
# NEXT_PUBLIC variable. Leave unset while the browser SDK surfaces are dormant.
# NEXT_PUBLIC_AZOA_BASE_URL=https://public-azoa-api.example.com

# ASP.NET Core Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ===========================================
# File Storage (S3-Compatible)
# ===========================================
# Provider: S3, Azure, Local (default: Local for development)
STORAGE_PROVIDER=Local

# S3 Configuration (AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces)
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=ardanova-files
S3_REGION=us-east-1
# Optional: Custom endpoint for S3-compatible services (MinIO, R2, etc.)
# S3_SERVICE_URL=http://localhost:9000
# S3_USE_PATH_STYLE=true

# Local Storage (for development)
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8080/files

# ===========================================
# AI Orchestrator Service
# ===========================================
ANTHROPIC_API_KEY=your-anthropic-api-key
MCP_SERVER_URL=http://localhost:8080

# ===========================================
# Algorand Blockchain (Future)
# ===========================================
# ALGOD_ADDRESS=https://testnet-api.algonode.cloud
# ALGOD_TOKEN=
# INDEXER_ADDRESS=https://testnet-idx.algonode.cloud
# INDEXER_TOKEN=

# ===========================================
# Docker/Production Overrides
# ===========================================
NODE_ENV=development

# Note: Replace all placeholder values with your actual configuration.
# For production, use strong secrets and enable SSL.
