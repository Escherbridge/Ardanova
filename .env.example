# ===========================================
# ArdaNova Platform - Root Environment Config
# ===========================================
# Copy this file to .env and fill in your values
# All services reference this root .env file

# ===========================================
# Authentication
# ===========================================
AUTH_SECRET=your-auth-secret-min-32-chars-here
AUTH_URL=http://localhost:3000

# Google OAuth (Primary provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Database
# ===========================================
# PostgreSQL connection string (Railway format with SSL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ardanova?sslmode=disable

# ===========================================
# Backend API
# ===========================================
API_URL=http://localhost:5147
# Must match the .NET API: env API_KEY, or ApiKey:Key in
# ardanova-backend-api-mcp/api-server/src/ArdaNova.API/appsettings.json (default dev-api-key-12345).
API_KEY=dev-api-key-12345

# ASP.NET Core Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ===========================================
# File Storage (S3-Compatible)
# ===========================================
# Provider: S3, Azure, Local (default: Local for development)
STORAGE_PROVIDER=Local

# S3 Configuration (AWS S3, MinIO, Cloudflare R2, DigitalOcean Spaces)
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET_NAME=ardanova-files
S3_REGION=us-east-1
# Optional: Custom endpoint for S3-compatible services (MinIO, R2, etc.)
# S3_SERVICE_URL=http://localhost:9000
# S3_USE_PATH_STYLE=true

# Local Storage (for development)
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8080/files

# ===========================================
# AI Orchestrator Service
# ===========================================
ANTHROPIC_API_KEY=your-anthropic-api-key
MCP_SERVER_URL=http://localhost:8080

# ===========================================
# Algorand Blockchain (Future)
# ===========================================
# ALGOD_ADDRESS=https://testnet-api.algonode.cloud
# ALGOD_TOKEN=
# INDEXER_ADDRESS=https://testnet-idx.algonode.cloud
# INDEXER_TOKEN=

# ===========================================
# Docker/Production Overrides
# ===========================================
NODE_ENV=development

# Note: Replace all placeholder values with your actual configuration.
# For production, use strong secrets and enable SSL.