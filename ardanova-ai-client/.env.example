# ===========================================
# ArdaNova AI Orchestrator - Environment Config
# ===========================================
# NOTE: In production/Docker, use the ROOT .env file instead.
# This file is for standalone local development only.

# ===========================================
# Claude AI (Anthropic)
# ===========================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===========================================
# MCP Server Connection
# ===========================================
# URL of the .NET Backend API (MCP Server)
MCP_SERVER_URL=http://localhost:8080

# API Key for authenticating with the backend
API_KEY=dev-api-key-12345

# ===========================================
# Server Configuration
# ===========================================
PORT=8081
DEBUG=false

# ===========================================
# IMPORTANT NOTE
# ===========================================
# For Docker deployments, all services use the root .env file.
# Ensure your configuration matches the root .env.example.
