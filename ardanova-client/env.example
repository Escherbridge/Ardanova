# Authentication
AUTH_SECRET=your-auth-secret-min-32-chars-here
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Local interface preview only; hosted runtimes ignore this flag.
DEV_AUTH_BYPASS=false

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ardanova

# ArdaNova Backend API
API_URL=http://localhost:5147
API_KEY=
ADMIN_API_KEY=
# Exact same sealed 32+ byte value as the .NET API service.
ACTOR_ASSERTION_HMAC_KEY=

# Optional browser-safe origin for dormant read-only AZOA SDK surfaces.
# Never expose the AZOA tenant API key as NEXT_PUBLIC_*.
# NEXT_PUBLIC_AZOA_BASE_URL=https://public-azoa-api.example.com

# Environment
NODE_ENV=development
