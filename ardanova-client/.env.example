# ===========================================
# ArdaNova Client (Next.js) - Environment Config
# ===========================================
# NOTE: In production/Docker, use the ROOT .env file instead.
# This file is for standalone local development only.

# ===========================================
# Authentication
# ===========================================
AUTH_SECRET=your-auth-secret-min-32-chars-here
AUTH_URL=http://localhost:3000

# Google OAuth (Primary provider)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Local UI preview only. Ignored outside `next dev` and on hosted runtimes.
# Never set this in Railway or any shared environment.
DEV_AUTH_BYPASS=false

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/ardanova

# ===========================================
# Backend API Connection
# ===========================================
API_URL=http://localhost:5147
# Same value as backend appsettings ApiKey:Key (see ardanova-backend-api-mcp/.../appsettings.json)
API_KEY=
# Distinct 32+ byte .NET admin policy key; required by production readiness and
# shared only with the frontend BFF.
ADMIN_API_KEY=
# 32+ byte shared HMAC secret with the .NET API. Configure the exact same
# sealed value on both Railway services. Never expose it as NEXT_PUBLIC_.
ACTOR_ASSERTION_HMAC_KEY=

# Optional public origin for the dormant browser-side, read-only AZOA SDK.
# Never expose the AZOA tenant API key as NEXT_PUBLIC_*.
# NEXT_PUBLIC_AZOA_BASE_URL=https://public-azoa-api.example.com

# ===========================================
# Node Environment
# ===========================================
NODE_ENV=development

# ===========================================
# IMPORTANT NOTE
# ===========================================
# For Docker deployments, all services use the root .env file.
# Ensure your configuration matches the root .env.example.
