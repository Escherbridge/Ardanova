Enum EventVisibility {
  PUBLIC
  PROJECT_MEMBERS
  GUILD_MEMBERS
  INVITE_ONLY
}

Enum AttendeeStatus {
  INVITED
  GOING
  MAYBE
  NOT_GOING
  ATTENDED
}

Table Event {
  id varchar [not null, pk, default: `cuid()`]
  title varchar [not null]
  slug varchar [not null, unique]
  description text
  type EventType [not null, default: 'MEETING']
  visibility EventVisibility [not null, default: 'PUBLIC']
  status EventStatus [not null, default: 'SCHEDULED']
  location varchar
  locationUrl varchar
  isOnline boolean [not null, default: false]
  meetingUrl varchar
  timezone varchar [not null, default: 'UTC']
  startDate datetime [not null]
  endDate datetime [not null]
  maxAttendees int
  attendeesCount int [not null, default: 0]
  coverImage varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  organizerId varchar [not null]
  projectId varchar
  guildId varchar
}
Ref: Event.organizerId > User.id
Ref: Event.projectId > Project.id
Ref: Event.guildId > Guild.id

Table EventAttendee {
  id varchar [not null, pk, default: `cuid()`]
  eventId varchar [not null]
  userId varchar [not null]
  status AttendeeStatus [not null, default: 'GOING']
  rsvpAt datetime [not null, default: `now()`]
  attendedAt datetime
  notes text

  indexes {
    (eventId, userId) [unique]
  }
}
Ref: EventAttendee.eventId > Event.id
Ref: EventAttendee.userId > User.id

Table EventCoHost {
  id varchar [not null, pk, default: `cuid()`]
  eventId varchar [not null]
  userId varchar [not null]
  addedAt datetime [not null, default: `now()`]

  indexes {
    (eventId, userId) [unique]
  }
}
Ref: EventCoHost.eventId > Event.id
Ref: EventCoHost.userId > User.id

Table EventReminder {
  id varchar [not null, pk, default: `cuid()`]
  eventId varchar [not null]
  userId varchar [not null]
  remindAt datetime [not null]
  isSent boolean [not null, default: false]
  sentAt datetime
  createdAt datetime [not null, default: `now()`]
}
Ref: EventReminder.eventId > Event.id
Ref: EventReminder.userId > User.id

