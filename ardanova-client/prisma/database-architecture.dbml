    (userId, guildId) [unique]
  }
}
Ref: GuildFollow.userId > User.id
Ref: GuildFollow.guildId > Guild.id

// =================================================================================================
// 10. Opportunities Module (Marketplace for Guilds, Projects, Tasks)
// =================================================================================================

Enum OpportunityType {
  GUILD_POSITION
  PROJECT_ROLE
  TASK_BOUNTY
  FREELANCE
  MENTORSHIP
  COLLABORATION
}

Enum OpportunityStatus {
  DRAFT
  OPEN
  IN_REVIEW
  FILLED
  CLOSED
  CANCELLED
}

Enum ExperienceLevel {
  ENTRY
  JUNIOR
  MID
  SENIOR
  LEAD
  EXPERT
}

Table Opportunity {
  id varchar [not null, pk, default: `cuid()`]
  title varchar [not null]
  slug varchar [not null, unique]
  description text [not null]
  type OpportunityType [not null]
  origin OpportunityOrigin [not null, default: 'TEAM_POSITION']
  status OpportunityStatus [not null, default: 'DRAFT']
  experienceLevel ExperienceLevel [not null, default: 'MID']
  requirements text
  skills text
  benefits text
  location varchar
  isRemote boolean [not null, default: true]
  compensation decimal(18,8)
  compensationDetails varchar
  deadline datetime
  maxApplications int
  applicationsCount int [not null, default: 0]
  bidsCount int [not null, default: 0]
  coverImage varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  closedAt datetime
  posterId varchar [not null]
  guildId varchar
  projectId varchar
  taskId varchar
  projectRole ProjectRole
}
Ref: Opportunity.posterId > User.id
Ref: Opportunity.guildId > Guild.id
Ref: Opportunity.projectId > Project.id
Ref: Opportunity.taskId > ProjectTask.id

Table OpportunityApplication {
  id varchar [not null, pk, default: `cuid()`]
  opportunityId varchar [not null]
  applicantId varchar [not null]
  coverLetter text [not null]
  portfolio text
  additionalInfo text
  status ApplicationStatus [not null, default: 'PENDING']
  reviewNotes text
  appliedAt datetime [not null, default: `now()`]
  reviewedAt datetime

  indexes {
    (opportunityId, applicantId) [unique]
  }
}
Ref: OpportunityApplication.opportunityId > Opportunity.id
Ref: OpportunityApplication.applicantId > User.id

Table OpportunityUpdate {
  id varchar [not null, pk, default: `cuid()`]
  opportunityId varchar [not null]
  userId varchar [not null]
  title varchar [not null]
  content text [not null]
  images text
