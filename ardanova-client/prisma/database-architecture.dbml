}
Ref: OpportunityUpdate.opportunityId > Opportunity.id
Ref: OpportunityUpdate.userId > User.id

Table OpportunityComment {
  id varchar [not null, pk, default: `cuid()`]
  opportunityId varchar [not null]
  userId varchar [not null]
  content text [not null]
  parentId varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: OpportunityComment.opportunityId > Opportunity.id
Ref: OpportunityComment.userId > User.id
Ref: OpportunityComment.parentId > OpportunityComment.id

Table OpportunityBid {
  id varchar [not null, pk, default: `cuid()`]
  opportunityId varchar [not null]
  bidderId varchar [not null]
  guildId varchar
