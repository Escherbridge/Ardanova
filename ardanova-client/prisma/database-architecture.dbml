  indexes {
    (opportunityId, bidderId) [unique]
  }
}
Ref: OpportunityBid.opportunityId > Opportunity.id
Ref: OpportunityBid.bidderId > User.id
Ref: OpportunityBid.guildId > Guild.id

// =================================================================================================
// 11. KYC & Identity Verification Module
// =================================================================================================

Enum KycStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

Enum KycDocumentType {
  GOVERNMENT_ID
  PASSPORT
  DRIVERS_LICENSE
  SELFIE
  PROOF_OF_ADDRESS
}

Enum KycProvider {
  MANUAL
  VERIFF
}

Table KycSubmission {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  provider KycProvider [not null, default: 'MANUAL']
  status KycStatus [not null, default: 'PENDING']
  reviewerId varchar [note: 'Admin who reviewed']
  reviewNotes text [note: 'Internal admin notes']
  rejectionReason varchar [note: 'User-facing rejection reason']
  providerSessionId varchar [note: 'External provider session ID']
  providerResult text [note: 'Raw JSON from provider']
  submittedAt datetime [not null, default: `now()`]
  reviewedAt datetime
  expiresAt datetime [note: 'KYC approval expiration']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (userId, status) [note: 'Query active submissions per user']
  }
}
Ref: KycSubmission.userId > User.id
Ref: KycSubmission.reviewerId > User.id

Table KycDocument {
  id varchar [not null, pk, default: `cuid()`]
  submissionId varchar [not null]
  type KycDocumentType [not null]
  fileUrl varchar [not null, note: 'S3/storage URL']
  fileName varchar [not null]
  mimeType varchar
  fileSizeBytes int
  metadata text [note: 'JSON: country, expiryDate, etc.']
  createdAt datetime [not null, default: `now()`]

  indexes {
    (submissionId, type) [unique, note: 'One document per type per submission']
  }
}
Ref: KycDocument.submissionId > KycSubmission.id

// =================================================================================================
// 12. Tokenomics & Project Equity Module (Track 09)
//
// Gated liquidity model with three holder classes (CONTRIBUTOR, INVESTOR, FOUNDER)
// and two project gates controlling when tokens become liquid.
// Three-bucket treasury: index fund (55%), liquid reserve (30%), operations (15%).
// =================================================================================================

Enum ProjectTokenStatus {
  PENDING     [note: 'Token config created, ASA not yet minted']
  ACTIVE      [note: 'ASA minted and operational']
  FROZEN      [note: 'Temporarily suspended']
  DISSOLVED   [note: 'Project ended, tokens retired']
}

Enum ProjectGateStatus {
  FUNDING    [note: 'Raising funds. No tokens liquid. Tasks disabled.']
  ACTIVE     [note: 'Gate 1 cleared. Tasks enabled. Contributor tokens liquid.']
  SUCCEEDED  [note: 'Gate 2 cleared. All tokens liquid.']
  FAILED     [note: 'Project failed. Founder tokens burned. Investor trust protection.']
}

Enum TokenHolderClass {
  CONTRIBUTOR [note: 'Earned through task completion. Liquid after Gate 1.']
  INVESTOR    [note: 'Purchased through crowdfunding. Locked until Gate 2.']
  FOUNDER     [note: 'Reserved for project creator. Locked until Gate 2. Burns on failure.']
}

Enum AllocationStatus {
  RESERVED    [note: 'Assigned to task, not yet distributed']
  DISTRIBUTED [note: 'Given to contributor']
  REVOKED     [note: 'Allocation cancelled']
  BURNED      [note: 'Founder tokens destroyed on project failure']
}

Enum PayoutStatus {
  PENDING     [note: 'Payout requested, awaiting processing']
  PROCESSING  [note: 'Conversion/payout in progress']
  COMPLETED   [note: 'USD delivered to contributor']
  FAILED      [note: 'Payout failed, tokens unlocked']
  CANCELLED   [note: 'Cancelled by user before processing']
}

Enum PlatformTreasuryTransactionType {
  FUNDING_INFLOW       [note: 'New project funding received']
  ALLOCATION_INDEX     [note: 'Inflow allocated to index fund']
  ALLOCATION_LIQUID    [note: 'Inflow allocated to liquid reserve']
  ALLOCATION_OPS       [note: 'Inflow allocated to operations']
  PAYOUT_DEBIT         [note: 'Fiat payout to contributor/investor']
  INDEX_RETURN         [note: 'Monthly index fund return applied']
  PROFIT_SHARE         [note: 'Platform profit share taken from index returns']
  REBALANCE            [note: 'Auto-rebalance from index to liquid']
  TRUST_PROTECTION     [note: 'Investor refund on project failure']
  FOUNDER_BURN         [note: 'Founder token burn — no treasury movement, supply reduction']
}

Table ProjectTokenConfig {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null, unique]
  assetId varchar [note: 'Algorand ASA ID — null until minted on-chain']
  assetDefinitionId varchar [note: 'Immutable canonical asset reference; nullable only during additive migration']
  assetName varchar [not null, note: 'e.g., ProjectName Shares']
  unitName varchar [not null, note: 'Max 8 chars, e.g., PSHARE']
  assetScale int [not null, default: 6, note: 'Canonical asset decimals fixed when the project token configuration is created']
  totalSupply int [not null, note: 'Fixed supply = 100% equity']
  allocatedSupply int [not null, default: 0]
  distributedSupply int [not null, default: 0]
  reservedSupply int [not null, default: 0, note: 'Founder/team reserve']
  mintTxHash varchar
  status ProjectTokenStatus [not null, default: 'PENDING']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  // Funding Gate (Gate 1)
  fundingGoal float [not null, note: 'USD amount required to clear Gate 1']
  fundingRaised float [not null, default: 0, note: 'USD raised so far']
  gateStatus ProjectGateStatus [not null, default: 'FUNDING']
  gate1ClearedAt datetime [note: 'When funding goal was met']
  gate2ClearedAt datetime [note: 'When project success was verified']
  failedAt datetime [note: 'When project was marked failed']

  // Holder class supply breakdown
  contributorSupply int [not null, default: 0, note: 'Tokens allocated/distributed to contributors']
  investorSupply int [not null, default: 0, note: 'Tokens allocated to investors']
  founderSupply int [not null, default: 0, note: 'Tokens reserved for founder(s)']
  burnedSupply int [not null, default: 0, note: 'Founder tokens burned on failure']

  // Success criteria
  successCriteria text [note: 'Description of what constitutes Gate 2 success']
  successVerifiedBy varchar [note: 'UserId of admin/community who verified success']
}
Ref: ProjectTokenConfig.projectId > Project.id

Table TokenAllocation {
  id varchar [not null, pk, default: `cuid()`]
  projectTokenConfigId varchar [not null]
  pbiId varchar [note: 'Nullable — PBI-level equity allocation']
  recipientUserId varchar [note: 'Null until distributed']
  equityPercentage float [not null, note: 'e.g., 2.5 = 2.5%']
  tokenAmount int [not null, note: 'Calculated: totalSupply * equityPercentage / 100']
  status AllocationStatus [not null, default: 'RESERVED']
  holderClass TokenHolderClass [not null, note: 'CONTRIBUTOR, INVESTOR, or FOUNDER']
  isLiquid boolean [not null, default: false, note: 'Derived from holderClass + project gateStatus']
  distributedAt datetime
  distributionTxHash varchar
  burnedAt datetime [note: 'Set when founder tokens are burned on project failure']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: TokenAllocation.projectTokenConfigId > ProjectTokenConfig.id
Ref: TokenAllocation.pbiId > ProductBacklogItem.id
Ref: TokenAllocation.recipientUserId > User.id

Table TokenBalance {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  projectTokenConfigId varchar [note: 'Null for ARDA token balance']
  isPlatformToken boolean [not null, default: false]
  holderClass TokenHolderClass [note: 'Which class this balance belongs to']
  isLiquid boolean [not null, default: false, note: 'Can this balance be traded/exited?']
  balance int [not null, default: 0]
  lockedBalance int [not null, default: 0, note: 'Locked for pending payouts']
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (userId, projectTokenConfigId, holderClass) [unique, note: 'One balance per user per project token per holder class']
  }
}
Ref: TokenBalance.userId > User.id
Ref: TokenBalance.projectTokenConfigId > ProjectTokenConfig.id

Table PayoutRequest {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  sourceProjectTokenConfigId varchar
  sourceTokenAmount int [not null]
  ardaTokenAmount int
  usdAmount float
  status PayoutStatus [not null, default: 'PENDING']
  holderClass TokenHolderClass [not null, note: 'Which holder class tokens are being exited']
  gateStatusAtRequest ProjectGateStatus [not null, note: 'Snapshot of project gate status when requested']
  conversionTxHash varchar
  payoutTxHash varchar
  stripePayoutId varchar
  failureReason varchar
  requestedAt datetime [not null, default: `now()`]
  processedAt datetime
  completedAt datetime
}
Ref: PayoutRequest.userId > User.id
Ref: PayoutRequest.sourceProjectTokenConfigId > ProjectTokenConfig.id

Table PlatformTreasury {
  id varchar [not null, pk, default: `cuid()`]
  singletonKey varchar [not null, unique, default: 'SINGLETON', note: 'Ensures only one treasury record exists']
  ardaTotalSupply bigint [not null]
  ardaCirculatingSupply bigint [not null, default: 0]
  ardaAssetId varchar [note: 'Algorand ASA ID for ARDA token']
  ardaMintTxHash varchar

  // Three-bucket treasury model
  indexFundBalance float [not null, default: 0, note: '55% of inflows. Compounding.']
  liquidReserveBalance float [not null, default: 0, note: '30% of inflows. Immediate payouts.']
  operationsBalance float [not null, default: 0, note: '15% of inflows. Platform ops.']

  // Allocation percentages (configurable)
  indexFundAllocationPct float [not null, default: 0.55]
  liquidReserveAllocationPct float [not null, default: 0.30]
  operationsAllocationPct float [not null, default: 0.15]

  // Index fund parameters
  indexFundAnnualReturn float [not null, default: 0.08]
  platformProfitSharePct float [not null, default: 0.25]
  trustProtectionRate float [not null, default: 0.50, note: '% of investor capital protected on project failure']

  // Tracking
  totalInflows float [not null, default: 0]
  totalPayouts float [not null, default: 0]
  totalRebalanceTransfers float [not null, default: 0, note: 'Cumulative index to liquid transfers']
  lastRebalanceAt datetime
  lastReconciliationAt datetime
  updatedAt datetime [not null, note: 'Updated at']
}

Table PlatformTreasuryTransaction {
  id varchar [not null, pk, default: `cuid()`]
  type PlatformTreasuryTransactionType [not null]
  amount float [not null]
  fromBucket varchar [note: 'index, liquid, operations, or external']
  toBucket varchar [note: 'index, liquid, operations, or external']
  relatedProjectId varchar
  relatedPayoutRequestId varchar
  description varchar
  balanceAfter float [not null, note: 'Total treasury after this transaction']
  createdAt datetime [not null, default: `now()`]
}

Table ProjectInvestment {
  id varchar [not null, pk, default: `cuid()`]
  projectTokenConfigId varchar [not null]
  userId varchar [not null]
  usdAmount float [not null, note: 'Amount invested in USD']
  tokenAmount int [not null, note: 'Project tokens received']
  stripePaymentIntentId varchar [unique, note: 'Stripe payment-intent id; database idempotency key for a completed funding allocation']
  investedAt datetime [not null, default: `now()`]

  // Trust protection
  protectionEligible boolean [not null, default: true]
  protectionPaidOut boolean [not null, default: false]
  protectionAmount float [note: 'USD refunded on project failure']
  protectionPaidAt datetime

  indexes {
    (projectTokenConfigId, userId) [note: 'Can have multiple investments']
  }
}
Ref: ProjectInvestment.projectTokenConfigId > ProjectTokenConfig.id
Ref: ProjectInvestment.userId > User.id

// =================================================================================================
// 18. Gated Commerce Settlement Module
// =================================================================================================

// ArdaNova owns the economic decision; AZOA owns the eventual custody operation.
// These records are intentionally inert until a transactionally-safe dispatcher is introduced.
Enum EconomicSettlementKind {
  TASK_REWARD
  FUNDING_ALLOCATION
  ESCROW_REFUND
  SWAP_SETTLEMENT
}

Enum EconomicSettlementStatus {
  DRAFT
  AUTHORIZED
  PENDING_DISPATCH
  SUBMITTED
  AWAITING_RECONCILIATION
  CONFIRMED
  REJECTED
  CANCELLED
  FAILED
}

Enum EconomicOutboxStatus {
  PENDING
  LEASED
  SUBMITTED
  AWAITING_RECONCILIATION
  COMPLETED
  FAILED
  CANCELLED
}

// A funding intent is the server-owned commerce record that a funding screen
// reads. Browser redirects and payment-provider callbacks never create or
// confirm an investment by themselves.
Enum FundingIntentStatus {
  DRAFT
  AWAITING_PAYMENT
  PAYMENT_VERIFIED
  SETTLEMENT_PENDING
  SETTLED
  REJECTED
  CANCELLED
  FAILED
}

// The accepted award terms never change. Operational links are added only as
// the task moves through escrow, quest, and settlement stages.
Enum TaskCommerceAgreementStatus {
  DRAFT
  ACCEPTED
  ESCROW_FUNDED
  QUEST_LINKED
  RELEASE_AUTHORIZED
  SETTLEMENT_PENDING
  SETTLED
  CANCELLED
  FAILED
}

// Stripe deliveries are acknowledged only after their signed event has a durable
// receipt. A short processing lease prevents a crashed worker from suppressing
// all later provider retries.
Enum StripeWebhookEventStatus {
  PROCESSING
  COMPLETED
  FAILED
}

Table StripeWebhookEvent {
  id varchar [not null, pk, note: 'Stripe event id; provider-level idempotency key']
  eventType varchar [not null]
  status StripeWebhookEventStatus [not null, default: 'PROCESSING']
  attemptCount int [not null, default: 1]
  receivedAt datetime [not null, default: `now()`]
  processingLeaseExpiresAt datetime [not null]
  completedAt datetime
  lastFailedAt datetime

  indexes {
    (status, processingLeaseExpiresAt)
  }
}

Table EconomicSettlement {
  id varchar [not null, pk, default: `cuid()`]
  kind EconomicSettlementKind [not null]
  status EconomicSettlementStatus [not null, default: 'DRAFT']
  idempotencyKey varchar [not null, unique, note: 'Stable semantic economic-event key; never random or timestamped']
  externalEventId varchar [unique, note: 'Payment-provider or other external event id when applicable']
  beneficiaryUserId varchar [not null]
  authorizedByUserId varchar
  projectId varchar
  taskId varchar
  escrowId varchar
  assetCode varchar [not null, note: 'Asset/currency identifier; no wallet secret material']
  assetDefinitionId varchar [note: 'Immutable canonical asset reference; nullable only during additive migration']
  projectTokenPolicyId varchar [note: 'Utility-token policy frozen by this economic decision']
  equityOrRedemptionRightPolicyId varchar [note: 'Separate rights policy when this decision concerns an equity or redemption right']
  eligibilityDecisionId varchar [note: 'Auditable authorization decision for a rights-bearing allocation']
  amount decimal(38,18) [not null, note: 'Fixed-scale settlement amount; floating point is forbidden']
  scale int [not null, default: 18]
  termsSnapshot json [note: 'Immutable authorization, gate, quote, and allocation-command snapshot']
  azoaOperationId varchar
  azoaReceipt json
  azoaReplayed boolean
  failureCode varchar
  failureDetail varchar
  version int [not null, default: 0, note: 'Optimistic-concurrency version for state transitions']
  createdAt datetime [not null, default: `now()`]
  authorizedAt datetime
  submittedAt datetime
  confirmedAt datetime
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (beneficiaryUserId, status)
    (projectId, status)
    (taskId, kind)
  }
}
Ref: EconomicSettlement.beneficiaryUserId > User.id
Ref: EconomicSettlement.authorizedByUserId > User.id
Ref: EconomicSettlement.projectId > Project.id
Ref: EconomicSettlement.taskId > ProjectTask.id
Ref: EconomicSettlement.escrowId > TaskEscrow.id

Table EconomicOutbox {
  id varchar [not null, pk, default: `cuid()`]
  settlementId varchar [not null, unique]
  status EconomicOutboxStatus [not null, default: 'PENDING']
  payloadVersion int [not null, default: 1]
  attemptCount int [not null, default: 0]
  availableAt datetime [not null, default: `now()`]
  leaseToken varchar
  leaseExpiresAt datetime
  lastAttemptAt datetime
  dispatchedAt datetime
  reconciliationRequiredAt datetime
  failureCode varchar
  failureDetail varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (status, availableAt)
    (leaseExpiresAt)
  }
}
// The unique settlementId enforces one durable dispatch claim per settlement.
// Use a normal FK here because the DBML generator cannot emit paired one-to-one
// Prisma relation names reliably; the database uniqueness is the authority.
Ref: EconomicOutbox.settlementId > EconomicSettlement.id

// Funding is local, durable, and actor-owned before a payment provider or
// custody operation is contacted. Settlement/outbox activation is deliberately
// deferred to a transactional orchestration slice.
Table FundingIntent {
  id varchar [not null, pk, default: `cuid()`]
  semanticKey varchar [not null, unique, note: 'Stable intent key scoped to funder, project token configuration, and disclosed terms']
  idempotencyKey varchar [not null, note: 'Caller replay key, unique within the funding actor']
  status FundingIntentStatus [not null, default: 'DRAFT']
  funderUserId varchar [not null]
  projectId varchar [not null]
  projectTokenConfigId varchar [not null]
  paymentAssetDefinitionId varchar [note: 'Canonical payment asset; nullable only during additive migration']
  awardAssetDefinitionId varchar [note: 'Canonical project utility or separately governed right asset; nullable only during additive migration']
  awardAmountAtoms varchar [note: 'Canonical non-negative base-unit string for the decided award; nullable only during additive migration']
  projectTokenPolicyId varchar [note: 'Utility-token policy frozen at authorization']
  equityOrRedemptionRightPolicyId varchar [note: 'Separate rights policy when funding is rights-bearing']
  eligibilityDecisionId varchar [note: 'Auditable rights-eligibility decision frozen at authorization']
  currencyCode varchar [not null, note: 'ISO currency code for the payment amount']
  amount decimal(38,18) [not null, note: 'Fixed-scale amount; floating point is forbidden']
  scale int [not null, default: 2]
  disclosureVersion varchar [not null]
  eligibilitySnapshot json [not null, note: 'Immutable eligibility and gate evidence at intent creation']
  termsSnapshot json [not null, note: 'Immutable funding terms, pricing, and allocation snapshot']
  termsHash varchar [not null, note: 'Canonical hash of the immutable terms snapshot']
  paymentProvider varchar
  providerCheckoutSessionId varchar [unique, note: 'Stripe Checkout session id; never returned by intent status']
  providerPaymentIntentId varchar [unique, note: 'Provider payment intent id once checkout is created']
  verifiedProviderEventId varchar [unique, note: 'Verified provider event id that authorizes local funding']
  settlementId varchar [unique, note: 'At most one local funding settlement; its outbox is reached through this settlement']
  expiresAt datetime
  paymentVerifiedAt datetime
  settledAt datetime
  cancelledAt datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (funderUserId, idempotencyKey) [unique]
    (funderUserId, status)
    (projectId, status)
    (projectTokenConfigId, status)
  }
}
Ref: FundingIntent.funderUserId > User.id
Ref: FundingIntent.projectId > Project.id
Ref: FundingIntent.projectTokenConfigId > ProjectTokenConfig.id
// The unique settlementId establishes a one-intent/one-economic-decision link.
// EconomicOutbox remains reachable through EconomicSettlement to avoid a
// duplicate dispatch relationship.
Ref: FundingIntent.settlementId > EconomicSettlement.id

// An accepted task award freezes commercial terms independently from mutable
// task, bid, escrow, or quest operational state.
Table TaskCommerceAgreement {
  id varchar [not null, pk, default: `cuid()`]
  semanticKey varchar [not null, unique, note: 'Stable accepted-award key; never random or timestamped']
  status TaskCommerceAgreementStatus [not null, default: 'DRAFT']
  projectId varchar [not null]
  taskId varchar [not null, unique, note: 'One commercial agreement per assigned task']
  bidId varchar [not null, unique, note: 'One accepted commercial agreement per bid']
  contributorUserId varchar [not null]
  projectTokenConfigId varchar
  assetDefinitionId varchar [note: 'Immutable canonical utility-asset reference; nullable only during additive migration']
  projectTokenPolicyId varchar [note: 'Utility-token policy frozen at task acceptance']
  equityOrRedemptionRightPolicyId varchar [note: 'Separate rights policy; task awards never infer one from utility-token state']
  eligibilityDecisionId varchar [note: 'Required when a task award carries a separate equity or redemption right']
  assetCode varchar [not null, note: 'Award asset identifier']
  awardAmount decimal(38,18) [not null, note: 'Fixed-scale project-token award; floating point is forbidden']
  scale int [not null, default: 18]
  acceptedTermsSnapshot json [not null, note: 'Immutable accepted bid, award, gate, and release terms']
  termsHash varchar [not null, note: 'Canonical hash of the immutable accepted terms']
  escrowId varchar [unique, note: 'Escrow linked after funding']
  questRunId varchar [note: 'AZOA quest-run reference; no AZOA credentials or secret material']
  settlementId varchar [unique, note: 'At most one reward/refund economic decision for this agreement']
  acceptedAt datetime
  releaseAuthorizedAt datetime
  settledAt datetime
  cancelledAt datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (contributorUserId, status)
    (projectId, status)
    (questRunId)
  }
}
Ref: TaskCommerceAgreement.projectId > Project.id
Ref: TaskCommerceAgreement.taskId > ProjectTask.id
Ref: TaskCommerceAgreement.bidId > OpportunityBid.id
Ref: TaskCommerceAgreement.contributorUserId > User.id
Ref: TaskCommerceAgreement.projectTokenConfigId > ProjectTokenConfig.id
Ref: TaskCommerceAgreement.escrowId > TaskEscrow.id
Ref: TaskCommerceAgreement.settlementId > EconomicSettlement.id

// Financial-engine vocabulary. These tables are intentionally additive: existing
// config, funding, agreement, and settlement rows receive nullable links first;
// a reviewed migration/backfill then validates historic facts before no-default
// NOT NULL hardening. See conductor/tracks/financial-engine-domain-hardening.
Enum AssetDefinitionKind {
  PROJECT_UTILITY
  ECOSYSTEM_UTILITY
  EQUITY_RIGHT
  REDEMPTION_RIGHT
  FIAT
}

Enum EquityOrRedemptionRightKind {
  EQUITY
  REDEMPTION
}

Enum EligibilityDecisionStatus {
  APPROVED
  REJECTED
  EXPIRED
  REVOKED
}

Enum EconomicSettlementLegKind {
  PAYMENT
  AWARD
  SOURCE
  INTERMEDIARY
  TARGET
  FEE
  REFUND
}

Enum SwapOrderStatus {
  DRAFT
  AUTHORIZED
  PENDING_SETTLEMENT
  CONFIRMED
  REJECTED
  CANCELLED
  FAILED
}

Table AssetDefinition {
  id varchar [not null, pk, default: `cuid()`]
  kind AssetDefinitionKind [not null]
  chainType varchar [not null]
  chainNetwork varchar [not null]
  canonicalAssetId varchar [not null, note: 'Canonical on-chain asset id; never inferred from symbol or display name']
  symbol varchar [not null]
  displayName varchar [not null]
  scale int [not null, note: 'Canonical decimal scale, inclusive range 0--18; no default is permitted']
  supersedesAssetDefinitionId varchar [note: 'Append-only correction lineage; historic agreements retain their original id']
  createdAt datetime [not null, default: `now()`]

  indexes {
    (chainType, chainNetwork, canonicalAssetId) [unique]
  }
}
Ref: AssetDefinition.supersedesAssetDefinitionId > AssetDefinition.id

Table ProjectTokenPolicy {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  assetDefinitionId varchar [not null]
  version int [not null]
  termsHash varchar [not null, note: 'Canonical hash of the immutable utility-token policy']
  allocationRules json [not null, note: 'Consumer-owned allocation, gate, and liquidity policy snapshot']
  effectiveFrom datetime [not null]
  retiredAt datetime
  createdAt datetime [not null, default: `now()`]

  indexes {
    (projectId, version) [unique]
  }
}
Ref: ProjectTokenPolicy.projectId > Project.id
Ref: ProjectTokenPolicy.assetDefinitionId > AssetDefinition.id

Table EquityOrRedemptionRightPolicy {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  kind EquityOrRedemptionRightKind [not null]
  version int [not null]
  jurisdiction varchar [not null]
  disclosureVersion varchar [not null]
  eligibilityPolicyVersion varchar [not null]
  termsHash varchar [not null, note: 'Canonical hash of the immutable rights policy']
  termsSnapshot json [not null, note: 'Consumer-owned cap, vesting, redemption, and disclosure terms']
  effectiveFrom datetime [not null]
  retiredAt datetime
  createdAt datetime [not null, default: `now()`]

  indexes {
    (projectId, kind, version) [unique]
  }
}
Ref: EquityOrRedemptionRightPolicy.projectId > Project.id

Table EligibilityDecision {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  equityOrRedemptionRightPolicyId varchar [not null]
  status EligibilityDecisionStatus [not null]
  evidenceDigest varchar [not null, note: 'Digest/reference only; no KYC document or payment secret is copied here']
  reasonCode varchar [not null]
  decidedByUserId varchar
  expiresAt datetime
  reviewedAt datetime
  createdAt datetime [not null, default: `now()`]

  indexes {
    (userId, equityOrRedemptionRightPolicyId, status)
    (expiresAt)
  }
}
Ref: EligibilityDecision.userId > User.id
Ref: EligibilityDecision.equityOrRedemptionRightPolicyId > EquityOrRedemptionRightPolicy.id
Ref: EligibilityDecision.decidedByUserId > User.id

// A settlement is a durable local decision; every newly authorized movement is
// represented by explicit legs rather than overloading a single amount with two
// different asset meanings. The existing settlement amount remains a legacy
// compatibility projection until its reviewed backfill is complete.
Table EconomicSettlementLeg {
  id varchar [not null, pk, default: `cuid()`]
  economicSettlementId varchar [not null]
  position int [not null, note: 'Zero-based immutable leg order within the settlement; migration must enforce position >= 0']
  kind EconomicSettlementLegKind [not null]
  assetDefinitionId varchar [not null]
  amountAtoms varchar [not null, note: 'Canonical positive base-unit string; migration must reject zero, signs, non-digits, and leading zeroes']
  createdAt datetime [not null, default: `now()`]

  indexes {
    (economicSettlementId, position) [unique]
  }
}
Ref: EconomicSettlementLeg.economicSettlementId > EconomicSettlement.id
Ref: EconomicSettlementLeg.assetDefinitionId > AssetDefinition.id

// The only supported exchange shape is project utility -> ARDA -> project
// utility. Rights policies are deliberately absent: equity or redemption rights
// cannot be quoted, exchanged, or inferred from utility-token liquidity.
Table SwapQuote {
  id varchar [not null, pk, default: `cuid()`]
  semanticKey varchar [not null, unique, note: 'Stable actor-scoped quote identity over immutable terms']
  actorUserId varchar [not null]
  sourceAssetDefinitionId varchar [not null]
  ardaAssetDefinitionId varchar [not null]
  targetAssetDefinitionId varchar [not null]
  sourceProjectTokenPolicyId varchar [not null]
  targetProjectTokenPolicyId varchar [not null]
  sourceAmountAtoms varchar [not null, note: 'Positive source utility-token base units']
  ardaAmountAtoms varchar [not null, note: 'Positive ARDA intermediary base units']
  targetAmountAtoms varchar [not null, note: 'Positive target utility-token base units']
  liquiditySnapshot json [not null]
  gateDecisionSnapshot json [not null]
  termsHash varchar [not null]
  expiresAt datetime [not null]
  createdAt datetime [not null, default: `now()`]

  indexes {
    (actorUserId, expiresAt)
  }
}
Ref: SwapQuote.actorUserId > User.id
Ref: SwapQuote.sourceAssetDefinitionId > AssetDefinition.id
Ref: SwapQuote.ardaAssetDefinitionId > AssetDefinition.id
Ref: SwapQuote.targetAssetDefinitionId > AssetDefinition.id
Ref: SwapQuote.sourceProjectTokenPolicyId > ProjectTokenPolicy.id
Ref: SwapQuote.targetProjectTokenPolicyId > ProjectTokenPolicy.id

Table SwapOrder {
  id varchar [not null, pk, default: `cuid()`]
  quoteId varchar [not null, unique]
  actorUserId varchar [not null]
  status SwapOrderStatus [not null, default: 'DRAFT']
  economicSettlementId varchar [unique, note: 'One accepted exchange order maps to at most one settlement; created only after the exact quote has been re-authorized']
  acceptedAt datetime
  confirmedAt datetime
  failureCode varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, default: `now()`]

  indexes {
    (actorUserId, status)
  }
}
Ref: SwapOrder.quoteId > SwapQuote.id
Ref: SwapOrder.actorUserId > User.id
Ref: SwapOrder.economicSettlementId - EconomicSettlement.id

// Additive compatibility links. They intentionally remain nullable until the
// reviewed backfill proves every historic value path has an authoritative asset,
// policy, and (where applicable) eligibility decision.
Ref: ProjectTokenConfig.assetDefinitionId > AssetDefinition.id
Ref: EconomicSettlement.assetDefinitionId > AssetDefinition.id
Ref: EconomicSettlement.projectTokenPolicyId > ProjectTokenPolicy.id
Ref: EconomicSettlement.equityOrRedemptionRightPolicyId > EquityOrRedemptionRightPolicy.id
Ref: EconomicSettlement.eligibilityDecisionId > EligibilityDecision.id
Ref: FundingIntent.paymentAssetDefinitionId > AssetDefinition.id
Ref: FundingIntent.awardAssetDefinitionId > AssetDefinition.id
Ref: FundingIntent.projectTokenPolicyId > ProjectTokenPolicy.id
Ref: FundingIntent.equityOrRedemptionRightPolicyId > EquityOrRedemptionRightPolicy.id
Ref: FundingIntent.eligibilityDecisionId > EligibilityDecision.id
Ref: TaskCommerceAgreement.assetDefinitionId > AssetDefinition.id
Ref: TaskCommerceAgreement.projectTokenPolicyId > ProjectTokenPolicy.id
Ref: TaskCommerceAgreement.equityOrRedemptionRightPolicyId > EquityOrRedemptionRightPolicy.id
Ref: TaskCommerceAgreement.eligibilityDecisionId > EligibilityDecision.id
