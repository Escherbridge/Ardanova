
// =================================================================================================
// 1. Authentication & User Core Module
// =================================================================================================

Enum UserRole {
  INDIVIDUAL
  GUILD
  ADMIN
}

Enum UserType {
  INNOVATOR
  SUPPORTER
  VOLUNTEER
  FREELANCER
  SME_OWNER
  GUILD_MEMBER
}

Enum UserTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

Enum VerificationLevel {
  ANONYMOUS
  VERIFIED
  PRO
  EXPERT
}

Table Account {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  type varchar [not null]
  provider varchar [not null]
  providerAccountId varchar [not null]
  refresh_token text
  access_token text
  expires_at int
  token_type varchar
  scope varchar
  id_token text
  session_state varchar
}
Ref: Account.userId > User.id

Table Session {
  id varchar [not null, pk, default: `cuid()`]
  sessionToken varchar [not null, unique]
  userId varchar [not null]
  expires datetime [not null]
}
Ref: Session.userId > User.id

Table User {
  id varchar [not null, pk, default: `cuid()`]
  email varchar [not null, unique]
  emailVerified datetime
  name varchar
  image varchar
  bio text
  location varchar
  phone varchar
  website varchar
  linkedIn varchar
  twitter varchar
  role UserRole [not null, default: 'INDIVIDUAL']
  userType UserType [not null, default: 'INNOVATOR']
  isVerified boolean [not null, default: false]
  totalXP int [not null, default: 0]
  level int [not null, default: 1]
  tier UserTier [not null, default: 'BRONZE']
  trustScore decimal(18,8) [not null, default: 0]
  verificationLevel VerificationLevel [not null, default: 'ANONYMOUS']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}

Table UserSkill {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  skill varchar [not null]
  level int [not null, default: 1]
}
Ref: UserSkill.userId > User.id

Table UserExperience {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  title varchar [not null]
  company varchar [not null]
  description text
  startDate datetime [not null]
  endDate datetime
  isCurrent boolean [not null, default: false]
}
Ref: UserExperience.userId > User.id

Table VerificationToken {
  id varchar [not null, pk, default: `cuid()`]
  identifier varchar [not null]
  token varchar [not null, unique]
  expires datetime [not null]
}
Ref: VerificationToken.identifier > User.id

Table Notification {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  type NotificationType [not null]
  title varchar [not null]
  message text [not null]
  data json
  isRead boolean [not null, default: false]
  readAt datetime
  actionUrl varchar
  createdAt datetime [not null, default: `now()`]
}
Ref: Notification.userId > User.id

Table Activity {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  projectId varchar
  type ActivityType [not null]
  entityType varchar [not null]
  entityId varchar [not null]
  action varchar [not null]
  metadata json
  createdAt datetime [not null, default: `now()`]
}
Ref: Activity.userId > User.id
Ref: Activity.projectId > Project.id

Enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_REVIEWED
  TASK_REVISION_REQUESTED
  PROPOSAL_CREATED
  PROPOSAL_VOTED
  PROPOSAL_PASSED
  PROPOSAL_REJECTED
  PROPOSAL_EXECUTED
  ACHIEVEMENT_EARNED
  LEVEL_UP
  STREAK_MILESTONE
  SHARES_RECEIVED
  SHARES_VESTED
  ESCROW_FUNDED
  ESCROW_RELEASED
  PROJECT_INVITATION
  PROJECT_INVITATION_ACCEPTED
  PROJECT_INVITATION_DECLINED
  PROJECT_MEMBERSHIP_REQUEST
  PROJECT_MEMBERSHIP_APPROVED
  PROJECT_MEMBERSHIP_REJECTED
  PROJECT_UPDATE
  PROJECT_FUNDED
  GUILD_INVITATION
  GUILD_INVITATION_ACCEPTED
  GUILD_INVITATION_DECLINED
  GUILD_APPLICATION
  GUILD_APPLICATION_APPROVED
  GUILD_APPLICATION_REJECTED
  EVENT_INVITATION
  EVENT_REMINDER
  EVENT_STARTING_SOON
  EVENT_CANCELLED
  EVENT_UPDATED
  USER_FOLLOWED
  PROJECT_FOLLOWED
  GUILD_FOLLOWED
  COMMENT_REPLY
  MENTION
  FOLLOWER_NEW
  MEMBERSHIP_GRANTED
  MEMBERSHIP_REVOKED
  MEMBERSHIP_SUSPENDED
  SYSTEM_ANNOUNCEMENT
  SECURITY_ALERT
}

Enum ActivityType {
  CREATED
  UPDATED
  DELETED
  COMPLETED
  JOINED
  LEFT
  COMMENTED
  VOTED
  SUBMITTED
  REVIEWED
  FUNDED
  TRANSFERRED
  SWAPPED
}

// =================================================================================================
// 2. Gamification & Reputation Module
// =================================================================================================

Enum XPEventType {
  TASK_COMPLETED
  PROPOSAL_CREATED
  PROPOSAL_PASSED
  VOTE_CAST
  PROJECT_FUNDED
  MEMBER_REFERRED
  ACHIEVEMENT_EARNED
  STREAK_MAINTAINED
  LEVEL_UP
  REVIEW_GIVEN
  CONTRIBUTION_MADE
}

Enum AchievementCategory {
  CONTRIBUTOR
  COLLABORATOR
  INVESTOR
  GOVERNANCE
  COMMUNITY
  STREAK
  MILESTONE
  GAMING
}

Enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

Enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ALL_TIME
}

Enum LeaderboardCategory {
  XP
  TASKS_COMPLETED
  SHARES_EARNED
  PROPOSALS_CREATED
  VOTES_CAST
  PROJECTS_FUNDED
}

Enum StreakType {
  DAILY_LOGIN
  DAILY_CONTRIBUTION
  WEEKLY_TASK
}

Enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
  CANCELLED
}

Table XPEvent {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  eventType XPEventType [not null]
  amount int [not null]
  source varchar [not null]
  sourceId varchar
  metadata json
  createdAt datetime [not null, default: `now()`]
}
Ref: XPEvent.userId > User.id

Table Achievement {
  id varchar [not null, pk, default: `cuid()`]
  name varchar [not null, unique]
  description varchar [not null]
  category AchievementCategory [not null]
  criteria json [not null]
  xpReward int [not null]
  equityReward decimal(18,8)
  rarity AchievementRarity [not null, default: 'COMMON']
  icon varchar
  isActive boolean [not null, default: true]
  createdAt datetime [not null, default: `now()`]
}

Table UserAchievement {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  achievementId varchar [not null]
  progress int [not null, default: 0]
  earnedAt datetime
}
Ref: UserAchievement.userId > User.id
Ref: UserAchievement.achievementId > Achievement.id

Table Leaderboard {
  id varchar [not null, pk, default: `cuid()`]
  period LeaderboardPeriod [not null]
  category LeaderboardCategory [not null]
  startDate datetime [not null]
  endDate datetime [not null]
  createdAt datetime [not null, default: `now()`]
}

Table LeaderboardEntry {
  id varchar [not null, pk, default: `cuid()`]
  leaderboardId varchar [not null]
  userId varchar [not null]
  rank int [not null]
  score int [not null]
  metadata json
}
Ref: LeaderboardEntry.leaderboardId > Leaderboard.id
Ref: LeaderboardEntry.userId > User.id

Table UserStreak {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null, unique]
  currentStreak int [not null, default: 0]
  longestStreak int [not null, default: 0]
  lastActivityDate datetime
  streakType StreakType [not null, default: 'DAILY_LOGIN']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: UserStreak.userId > User.id

Table Referral {
  id varchar [not null, pk, default: `cuid()`]
  referrerId varchar [not null]
  referredId varchar [not null, unique]
  referralCode varchar
  status ReferralStatus [not null, default: 'PENDING']
  rewardClaimed boolean [not null, default: false]
  xpRewarded int
  equityRewarded decimal(18,8)
  createdAt datetime [not null, default: `now()`]
  completedAt datetime
}
Ref: Referral.referrerId > User.id
Ref: Referral.referredId > User.id

// =================================================================================================
// 3. Project Management & Governance Module
// =================================================================================================

Enum ProjectType {
  TEMPORARY
  LONG_TERM
  FOUNDATION
  BUSINESS
  PRODUCT
  OPEN_SOURCE
  COMMUNITY
}

Enum ProjectDuration {
  ONE_TWO_WEEKS
  ONE_THREE_MONTHS
  THREE_SIX_MONTHS
  SIX_TWELVE_MONTHS
  ONE_TWO_YEARS
  TWO_PLUS_YEARS
  ONGOING
}

Enum ProjectStatus {
  DRAFT
  PUBLISHED
  SEEKING_SUPPORT
  FUNDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

Enum ProjectCategory {
  TECHNOLOGY
  HEALTHCARE
  EDUCATION
  ENVIRONMENT
  SOCIAL_IMPACT
  BUSINESS
  ARTS_CULTURE
  AGRICULTURE
  FINANCE
  OTHER
}

Enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
  BLOCKED
}

Enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

Enum TaskType {
  FEATURE
  BUG
  ENHANCEMENT
  DOCUMENTATION
  RESEARCH
  DESIGN
  TESTING
  REVIEW
  MAINTENANCE
  OTHER
}

Enum SupportType {
  VOTE
  SUBSCRIPTION
  VOLUNTEER
  RESOURCE
}

Enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

Enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

Enum MembershipRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}



Enum EpicStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

Enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

Enum PBIType {
  FEATURE
  ENHANCEMENT
  BUG
  TECHNICAL_DEBT
  SPIKE
}

Enum PBIStatus {
  NEW
  READY
  IN_PROGRESS
  DONE
  CANCELLED
}



Enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

Enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

Enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

Enum OpportunityOrigin {
  TASK_GENERATED
  TEAM_POSITION
}

Enum ProjectRole {
  FOUNDER
  LEADER
  CORE_CONTRIBUTOR
  CONTRIBUTOR
  OBSERVER
}

Enum CompensationModel {
  FIXED_SHARES
  HOURLY_SHARES
  EQUITY_PERCENT
  HYBRID
  BOUNTY
  MILESTONE
}

Enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

Enum ProposalType {
  TREASURY
  GOVERNANCE
  STRATEGIC
  OPERATIONAL
  EMERGENCY
  CONSTITUTIONAL
  SHARES
}

Enum ProposalStatus {
  DRAFT
  ACTIVE
  PASSED
  REJECTED
  EXECUTED
  CANCELLED
  EXPIRED
}

Table Project {
  id varchar [not null, pk, default: `cuid()`]
  title varchar [not null]
  slug varchar [not null, unique]
  description text [not null]
  problemStatement text [not null]
  solution text [not null]
  categories text [not null, default: 'OTHER', note: 'Comma-separated ProjectCategory values']
  projectType ProjectType [not null, default: 'TEMPORARY']
  duration ProjectDuration
  status ProjectStatus [not null, default: 'DRAFT']
  fundingGoal decimal(18,8)
  currentFunding decimal(18,8) [not null, default: 0.00]
  supportersCount int [not null, default: 0]
  votesCount int [not null, default: 0]
  viewsCount int [not null, default: 0]
  featured boolean [not null, default: false]
  isTrending boolean [not null, default: false]
  trendingScore decimal(18,8) [not null, default: 0]
  trendingRank int
  trendingAt datetime
  tags text
  images text
  videos text
  documents text
  targetAudience text
  expectedImpact text
  timeline text
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  publishedAt datetime
  fundedAt datetime
  completedAt datetime
  commerceEnabled boolean [not null, default: false]
  storefrontDescription text
  createdById varchar [not null]
  assignedGuildId varchar
}
Ref: Project.createdById > User.id
Ref: Project.assignedGuildId > Guild.id

Table ProjectTask {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  pbiId varchar
  title varchar [not null]
  description text
  status TaskStatus [not null, default: 'TODO']
  priority TaskPriority [not null, default: 'MEDIUM']
  taskType TaskType [not null, default: 'FEATURE']
  estimatedHours int
  actualHours int
  equityReward decimal(18,8)
  escrowStatus EscrowStatus [not null, default: 'NONE']
  dueDate datetime
  completedAt datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assignedToId varchar
  opportunityId varchar [unique, note: 'Auto-generated opportunity for this task']
}
Ref: ProjectTask.projectId > Project.id
Ref: ProjectTask.assignedToId > User.id
Ref: ProjectTask.pbiId > ProductBacklogItem.id
Ref: ProjectTask.opportunityId > Opportunity.id

Table ProjectTaskDependency {
  id varchar [not null, pk, default: `cuid()`]
  taskId varchar [not null]
  dependsOnId varchar [not null]
}
Ref: ProjectTaskDependency.taskId > ProjectTask.id
Ref: ProjectTaskDependency.dependsOnId > ProjectTask.id

Table ProjectResource {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  name varchar [not null]
  description text
  quantity int [not null, default: 1]
  estimatedCost decimal
  recurringCost decimal
  recurringIntervalDays int
  isRequired boolean [not null, default: true]
  isObtained boolean [not null, default: false]
  createdAt datetime [not null, default: `now()`]
}
Ref: ProjectResource.projectId > Project.id

Table ProjectMilestone {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  title varchar [not null]
  description text
  targetDate datetime
  completedAt datetime
  status MilestoneStatus [not null, default: 'PLANNED']
  priority Priority [not null, default: 'MEDIUM']
  order int [not null, default: 0]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assigneeId varchar
}
Ref: ProjectMilestone.projectId > Project.id
Ref: ProjectMilestone.assigneeId > User.id

Table ProjectSupport {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  supportType SupportType [not null]
  monthlyAmount decimal
  message text
  isActive boolean [not null, default: true]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ProjectSupport.projectId > Project.id
Ref: ProjectSupport.userId > User.id

Table ProjectApplication {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  roleTitle varchar [not null]
  message text [not null]
  skills text
  experience text
  availability varchar
  status ApplicationStatus [not null, default: 'PENDING']
  appliedAt datetime [not null, default: `now()`]
  reviewedAt datetime
  reviewMessage text
}
Ref: ProjectApplication.projectId > Project.id
Ref: ProjectApplication.userId > User.id

Table ProjectInvitation {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  invitedById varchar [not null]
  invitedUserId varchar
  invitedEmail varchar
  role ProjectRole [not null, default: 'CONTRIBUTOR']
  message text
  status InvitationStatus [not null, default: 'PENDING']
  token varchar [unique]
  expiresAt datetime
  createdAt datetime [not null, default: `now()`]
  respondedAt datetime
}
Ref: ProjectInvitation.projectId > Project.id
Ref: ProjectInvitation.invitedById > User.id
Ref: ProjectInvitation.invitedUserId > User.id

Table ProjectMembershipRequest {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  requestedRole ProjectRole [not null, default: 'CONTRIBUTOR']
  message text [not null]
  skills text
  motivation text
  portfolio text
  status MembershipRequestStatus [not null, default: 'PENDING']
  reviewedById varchar
  reviewMessage text
  createdAt datetime [not null, default: `now()`]
  reviewedAt datetime
}
Ref: ProjectMembershipRequest.projectId > Project.id
Ref: ProjectMembershipRequest.userId > User.id
Ref: ProjectMembershipRequest.reviewedById > User.id

Table ProjectComment {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  content text [not null]
  parentId varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ProjectComment.projectId > Project.id
Ref: ProjectComment.userId > User.id
Ref: ProjectComment.parentId > ProjectComment.id

Table ProjectUpdate {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  title varchar [not null]
  content text [not null]
  images text
  createdAt datetime [not null, default: `now()`]
}
Ref: ProjectUpdate.projectId > Project.id
Ref: ProjectUpdate.userId > User.id



Table Epic {
  id varchar [not null, pk, default: `cuid()`]
  milestoneId varchar [not null]
  title varchar [not null]
  description text
  status EpicStatus [not null, default: 'PLANNED']
  priority Priority [not null, default: 'MEDIUM']
  equityBudget decimal
  progress int [not null, default: 0]
  startDate datetime
  targetDate datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assigneeId varchar
}
Ref: Epic.milestoneId > ProjectMilestone.id
Ref: Epic.assigneeId > User.id

Table Sprint {
  id varchar [not null, pk, default: `cuid()`]
  epicId varchar [not null]
  name varchar [not null]
  goal text
  startDate datetime [not null]
  endDate datetime [not null]
  equityBudget decimal
  velocity int
  status SprintStatus [not null, default: 'PLANNED']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assigneeId varchar
}
Ref: Sprint.epicId > Epic.id
Ref: Sprint.assigneeId > User.id

Table Feature {
  id varchar [not null, pk, default: `cuid()`]
  sprintId varchar [not null]
  title varchar [not null]
  description text
  status FeatureStatus [not null, default: 'PLANNED']
  priority Priority [not null, default: 'MEDIUM']
  order int [not null, default: 0]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assigneeId varchar
}
Ref: Feature.sprintId > Sprint.id
Ref: Feature.assigneeId > User.id

Table ProductBacklogItem {
  id varchar [not null, pk, default: `cuid()`]
  featureId varchar [not null]
  title varchar [not null]
  description text
  type PBIType [not null, default: 'FEATURE']
  storyPoints int
  status PBIStatus [not null, default: 'NEW']
  acceptanceCriteria text
  priority Priority [not null, default: 'MEDIUM']
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
  assigneeId varchar
}
Ref: ProductBacklogItem.featureId > Feature.id
Ref: ProductBacklogItem.assigneeId > User.id



Table ProjectMember {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  role ProjectRole [not null, default: 'OBSERVER']
  shareBalance decimal [not null, default: 0, note: 'Economic rights - proportional to holdings']
  votingPower decimal [not null, default: 0, note: 'Governance rights - binary (0 or 1), derived from MembershipCredential ownership']
  joinedAt datetime [not null, default: `now()`]
  invitedById varchar
}
Ref: ProjectMember.projectId > Project.id
Ref: ProjectMember.userId > User.id

Table TaskCompensation {
  id varchar [not null, pk, default: `cuid()`]
  taskId varchar [not null, unique]
  compensationModel CompensationModel [not null, default: 'FIXED_SHARES']
  shareAmount decimal
  hourlyRate decimal
  equityPercent decimal
  stableCoinAmount decimal
  vestingMonths int
  createdAt datetime [not null, default: `now()`]
}
Ref: TaskCompensation.taskId > ProjectTask.id

Table TaskSubmission {
  id varchar [not null, pk, default: `cuid()`]
  taskId varchar [not null]
  submittedById varchar [not null]
  content text [not null]
  attachments text
  status SubmissionStatus [not null, default: 'PENDING']
  reviewedById varchar
  feedback text
  submittedAt datetime [not null, default: `now()`]
  reviewedAt datetime
}
Ref: TaskSubmission.taskId > ProjectTask.id
Ref: TaskSubmission.submittedById > User.id
Ref: TaskSubmission.reviewedById > User.id

Table Proposal {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  creatorId varchar [not null]
  type ProposalType [not null]
  title varchar [not null]
  description text [not null]
  options json [not null]
  quorum int [not null]
  threshold int [not null]
  status ProposalStatus [not null, default: 'DRAFT']
  votingStart datetime
  votingEnd datetime
  executionDelay int
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: Proposal.projectId > Project.id
Ref: Proposal.creatorId > User.id

Table Vote {
  id varchar [not null, pk, default: `cuid()`]
  proposalId varchar [not null]
  voterId varchar [not null]
  choice int [not null]
  weight decimal [not null]
  reason text
  txHash varchar
  createdAt datetime [not null, default: `now()`]
}
Ref: Vote.proposalId > Proposal.id
Ref: Vote.voterId > User.id

Table ProposalExecution {
  id varchar [not null, pk, default: `cuid()`]
  proposalId varchar [not null, unique]
  executedAt datetime [not null, default: `now()`]
  txHash varchar
  result json
}
Ref: ProposalExecution.proposalId > Proposal.id

Table ProposalComment {
  id varchar [not null, pk, default: `cuid()`]
  proposalId varchar [not null]
  userId varchar [not null]
  content text [not null]
  parentId varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ProposalComment.proposalId > Proposal.id
Ref: ProposalComment.userId > User.id
Ref: ProposalComment.parentId > ProposalComment.id

Table DelegatedVote {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  delegatorId varchar [not null]
  delegateeId varchar [not null]
  shareId varchar [not null]
  amount decimal [not null]
  isActive boolean [not null, default: true]
  createdAt datetime [not null, default: `now()`]
  expiresAt datetime
  revokedAt datetime
}
Ref: DelegatedVote.projectId > Project.id
Ref: DelegatedVote.delegatorId > User.id
Ref: DelegatedVote.delegateeId > User.id
Ref: DelegatedVote.shareId > ProjectShare.id

// =================================================================================================
// 4. Guild Module
// =================================================================================================

Enum BidStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}


Table Guild {
  id varchar [not null, pk, default: `cuid()`]
  name varchar [not null]
  slug varchar [not null, unique]
  description text [not null]
  website varchar
  email varchar [not null]
  phone varchar
  address text
  logo varchar
