  createdAt datetime [not null, default: `now()`]
  fundedAt datetime
  releasedAt datetime
  refundedAt datetime
}
Ref: TaskEscrow.taskId > ProjectTask.id
Ref: TaskEscrow.funderId > User.id
Ref: TaskEscrow.shareId > ProjectShare.id

Table ShareSwap {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  fromShareId varchar [not null]
  toShareId varchar [not null]
  fromAmount decimal [not null]
