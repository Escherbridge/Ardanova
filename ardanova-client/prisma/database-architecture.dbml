  APPLICATION_APPROVED
  GAME_SDK_THRESHOLD
}

// =================================================================================================
// 6a. Dual-Asset Model: Governance (MembershipCredential) + Economic (ProjectShare)
//
// MembershipCredential = Governance rights (soulbound ASA, non-transferable, one-member-one-vote)
// ProjectShare  = Economic rights (fungible, transferable, proportional to holdings)
//
// A member's VOTE is always equal (1 credential = 1 vote, regardless of share balance).
// A member's DIVIDEND is proportional to their share holdings.
// Membership cannot be purchased — only earned through contribution, approval, or DAO vote.
// =================================================================================================

Table MembershipCredential {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [note: 'Nullable — credential for a project']
  guildId varchar [note: 'Nullable — credential for a guild']
  userId varchar [not null]
  assetId varchar [note: 'Algorand ASA ID for this soulbound credential']
  status MembershipCredentialStatus [not null, default: 'ACTIVE']
  isTransferable boolean [not null, default: false, note: 'Soulbound — always false']
  tier UserTier [note: 'Credential tier: BRONZE, SILVER, GOLD, PLATINUM, DIAMOND']
  grantedVia MembershipGrantType [not null]
  grantedByProposalId varchar [note: 'Populated if membership was granted via DAO vote']
  metadataUri varchar [note: 'ARC-19 metadata URI (IPFS or HTTP)']
  mintTxHash varchar
  revokeTxHash varchar
  mintedAt datetime
  revokedAt datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']

  indexes {
    (projectId, userId) [unique, note: 'One credential per user per project']
    (guildId, userId) [unique, note: 'One credential per user per guild']
  }
}
Ref: MembershipCredential.projectId > Project.id
Ref: MembershipCredential.guildId > Guild.id
Ref: MembershipCredential.userId > User.id
Ref: MembershipCredential.grantedByProposalId > Proposal.id

// ProjectShare represents ECONOMIC rights only — ownership stakes with proportional dividends.
// Governance voting power is NOT derived from share balance; it comes from MembershipCredential.
Table ProjectShare {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null, unique]
  assetId varchar
  name varchar [not null]
  symbol varchar [not null]
  totalSupply decimal [not null]
  decimals int [not null, default: 6]
  allocation json [not null]
  vestingConfig json
  isDeployed boolean [not null, default: false]
  deployedAt datetime
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ProjectShare.projectId > Project.id

Table ProjectEquity {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null]
  userId varchar [not null]
  sharePercent decimal [not null]
  investmentAmount decimal [not null]
  grantedAt datetime [not null, default: `now()`]
}
Ref: ProjectEquity.projectId > Project.id
Ref: ProjectEquity.userId > User.id

Table Treasury {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null, unique]
  balance decimal [not null, default: 0]
  shareAssetId varchar
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: Treasury.projectId > Project.id

Table TreasuryTransaction {
  id varchar [not null, pk, default: `cuid()`]
  treasuryId varchar [not null]
  type TransactionType [not null]
  amount decimal [not null]
  description varchar
  txHash varchar
  proposalId varchar
  createdAt datetime [not null, default: `now()`]
}
Ref: TreasuryTransaction.treasuryId > Treasury.id

Table ShareHolder {
  id varchar [not null, pk, default: `cuid()`]
  shareId varchar [not null]
  userId varchar [not null]
  balance decimal [not null]
  stakedAmount decimal [not null, default: 0]
  lockedAmount decimal [not null, default: 0]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ShareHolder.shareId > ProjectShare.id
Ref: ShareHolder.userId > User.id

Table ShareVesting {
  id varchar [not null, pk, default: `cuid()`]
  holderId varchar [not null]
  totalAmount decimal [not null]
  releasedAmount decimal [not null, default: 0]
  startDate datetime [not null]
