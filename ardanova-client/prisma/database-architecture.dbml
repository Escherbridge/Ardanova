  createdAt datetime [not null, default: `now()`]
}
Ref: FundraisingContribution.fundraisingId > Fundraising.id
Ref: FundraisingContribution.userId > User.id

Table Wallet {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  address varchar [not null, unique]
  provider WalletProvider [not null]
  label varchar
  isVerified boolean [not null, default: false]
  verifiedAt datetime
  verificationChain varchar
  verificationNetwork varchar
  verificationChallengeId varchar
  isPrimary boolean [not null, default: false]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: Wallet.userId > User.id

Table WalletVerificationChallenge {
  id varchar [not null, pk, default: `cuid()`]
  userId varchar [not null]
  walletId varchar [not null]
  address varchar [not null, note: 'Canonical public Algorand address only']
  chain varchar [not null, note: 'Canonical chain identifier']
  network varchar [not null, note: 'Canonical network identifier']
  nonceHash varchar [not null, note: 'SHA-256 of a CSPRNG nonce; never persist the nonce']
  issuedAt datetime [not null, default: `now()`]
  expiresAt datetime [not null]
  consumedAt datetime
  proofVerified boolean
  signatureHash varchar [note: 'SHA-256 audit digest; never persist the submitted signature']
  failureCode varchar

  indexes {
    (walletId, consumedAt)
    (userId, expiresAt)
  }
}
Ref: WalletVerificationChallenge.userId > User.id
Ref: WalletVerificationChallenge.walletId > Wallet.id

// A signed BFF actor assertion is single-use. The primary key is deliberately
// retained after expiry so an assertion id can never be reclaimed.
Table ActorAssertionReplay {
  jti varchar [not null, pk, note: 'Single-use assertion UUID; never reclaimed']
  expiresAt datetime [not null]
  consumedAt datetime [not null, default: `now()`]
  subject varchar [not null]
  requestTarget varchar [not null]
  bodySha256 varchar [not null]

  indexes {
    (expiresAt)
  }
}

Table ProjectWallet {
  id varchar [not null, pk, default: `cuid()`]
  projectId varchar [not null, unique, note: 'One wallet per project']
  address varchar [unique, note: 'On-chain address (Algorand) - null if custodial/off-chain']
  provider WalletProvider [not null, default: 'PERA']
  label varchar [default: 'Project Treasury']
  balance decimal [not null, default: 0, note: 'Off-chain tracked balance of project tokens']
  reservedBalance decimal [not null, default: 0, note: 'Locked for escrow/vesting']
  isVerified boolean [not null, default: false]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: ProjectWallet.projectId > Project.id

Table GuildWallet {
  id varchar [not null, pk, default: `cuid()`]
  guildId varchar [not null, unique, note: 'One wallet per guild']
  address varchar [unique, note: 'On-chain address (Algorand) - null if custodial/off-chain']
  provider WalletProvider [not null, default: 'PERA']
  label varchar [default: 'Guild Treasury']
  balance decimal [not null, default: 0, note: 'Off-chain tracked balance']
  reservedBalance decimal [not null, default: 0, note: 'Locked for escrow/vesting']
  isVerified boolean [not null, default: false]
  createdAt datetime [not null, default: `now()`]
  updatedAt datetime [not null, note: 'Updated at']
}
Ref: GuildWallet.guildId > Guild.id

