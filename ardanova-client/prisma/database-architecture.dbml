  updatedAt datetime [not null, note: 'Updated at']
}
Ref: LiquidityPool.share1Id > ProjectShare.id
Ref: LiquidityPool.share2Id > ProjectShare.id

Table LiquidityProvider {
  id varchar [not null, pk, default: `cuid()`]
